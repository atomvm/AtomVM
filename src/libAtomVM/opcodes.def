/*
 * Signature letters (OTP-aligned, see erts/emulator/internal_doc/beam_makeops.md)
 *
 * DECODE_COMPACT_TERM:
 *   s  source term (register or constant)
 *   c  constant-only source
 *
 * DECODE_DEST_REGISTER:
 *   d  destination register (X or Y)
 *   S  source register only (X or Y, read not written)
 *
 * DECODE_XREG:
 *   x  X register
 *
 * DECODE_YREG:
 *   y  Y register
 *
 * DECODE_ATOM:
 *   a  atom constant
 *
 * DECODE_LABEL:
 *   f  failure label (non-zero, branch/call target)
 *   j  fail label (0 = no fail / fall through)
 *
 * DECODE_LITERAL:
 *   t  small word / immediate (up to 12 bits)
 *   I  wider word / immediate (up to 32 bits)
 *   A  arity
 *   P  tuple/byte offset
 *   Q  stack/frame offset
 *   e  export/import entry index
 *   b  BIF index
 *   F  fun/lambda entry index
 *
 * DECODE_FP_REGISTER:
 *   l  floating point register
 *
 * DECODE_ATOM_OR_LABEL:
 *   m  atom-or-label (e.g. bs_start_match4 fail arg)
 *
 * DECODE_ALLOCATOR_LIST:
 *   z  allocator list (e.g. test_heap, allocate_heap)
 *
 * Extended list loop:
 *   [X]  DECODE_EXTENDED_LIST_TAG + DECODE_LITERAL(count), then repeat X
 *        until count items are consumed. Each decoded character inside the
 *        brackets decrements the count; when it reaches 0 the loop ends.
 *        Example: [sf] with count=6 decodes 3 pairs of (source, label).
 *
 * End of code section:
 *   $  stop parsing and return offset (used by int_call_end)
 *
 * Handler placeholder:
 *   -  no-op (custom handler does the decoding)
 */

// Remember to keep this list in sync with libs/jit/src/opcodes.hrl

X_OPCODE_HANDLER(OP_LABEL, 1, label, "I") // label definition id: DECODE_LITERAL, not DECODE_LABEL

 *
 * AtomVM compile-time atoms for the configured STM32 device.
 * Each atom is encoded as a length-prefixed string literal using two
 * adjacent string literals so the C compiler never greedily extends
 * the \xNN hex escape into the following text characters.
 */

#ifndef STM32_DEVICE_ATOMS_H
#define STM32_DEVICE_ATOMS_H

/* series atom: "@STM32_SERIES_ATOM_STR@" (length @STM32_SERIES_ATOM_LEN_DEC@) */
#define STM32_SERIES_ATOM_LITERAL "\x@STM32_SERIES_ATOM_LEN_HEX@" "@STM32_SERIES_ATOM_STR@"

/* cpu atom: "@STM32_CPU_ATOM_STR@" (length @STM32_CPU_ATOM_LEN_DEC@) */
#define STM32_CPU_ATOM_LITERAL "\x@STM32_CPU_ATOM_LEN_HEX@" "@STM32_CPU_ATOM_STR@"

/* fpu atom: "@STM32_FPU_ATOM_STR@" (length @STM32_FPU_ATOM_LEN_DEC@) */
#define STM32_FPU_ATOM_LITERAL "\x@STM32_FPU_ATOM_LEN_HEX@" "@STM32_FPU_ATOM_STR@"

/* device atom: "@STM32_DEVICE_ATOM_STR@" (length @STM32_DEVICE_ATOM_LEN_DEC@) */
#define STM32_DEVICE_ATOM_LITERAL "\x@STM32_DEVICE_ATOM_LEN_HEX@" "@STM32_DEVICE_ATOM_STR@"

#endif /* STM32_DEVICE_ATOMS_H */
